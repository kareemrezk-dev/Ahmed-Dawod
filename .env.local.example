# ─── Admin Panel ──────────────────────────────────────────────────────────────
# SHA-256 hash of admin password (required — dashboard won't open without it)
# To generate: https://emn178.github.io/online-tools/sha256.html
# Example: hash your password there, then paste the result below
NEXT_PUBLIC_ADMIN_HASH=your_sha256_hash_here

# Supabase (optional pricing/coupons)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
